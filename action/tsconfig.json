{
  "compilerOptions": {
    "outDir": "dist",
    "target": "ESNext",
    "module": "ESNext",
    "sourceMap": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "suppressImplicitAnyIndexErrors": true,
    "declarationDir": "dist/types",
    "declaration": true,
    "lib": [
      "ESNext"
    ],
  },
  "include": [
    "src/**/*.mts",
  ]
}